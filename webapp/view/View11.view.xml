<mvc:View controllerName="demo.practice.practice.controller.View11"
xmlns:core="sap.ui.core"
xmlns:mvc="sap.ui.core.mvc" 
xmlns="sap.m"
>

    <VBox class="sapUiSmallMargin" width="20rem">
         <Title text="Static dropdown (select)" class="sapUiSmallMarginBottom"/>

         <Select 
           id="dynamicSelect"
           selectedKey="{/selectedKey}"
           items="{/dropdownItems}"
           change="onSelectionChange"
         >
              <core:Item key="{key}" text="{text}"/>
            
         </Select>
        
    </VBox>



</mvc:View>